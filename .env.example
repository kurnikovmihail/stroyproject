# --- API ---
API_PORT=3000

# --- amoCRM integration ---
# Set true when credentials are configured and tested
AMO_ENABLED=false

# e.g. mycompany (for https://mycompany.amocrm.ru)
AMO_SUBDOMAIN=

# Auth mode:
# - oauth: requires AMO_CLIENT_ID, AMO_CLIENT_SECRET, AMO_REDIRECT_URI, AMO_REFRESH_TOKEN
# - token: requires AMO_LONG_LIVED_TOKEN
AMO_AUTH_MODE=oauth

# OAuth mode credentials
AMO_CLIENT_ID=
AMO_CLIENT_SECRET=
AMO_REDIRECT_URI=
AMO_REFRESH_TOKEN=

# Long-lived token mode
AMO_LONG_LIVED_TOKEN=

# Optional, if you want to put leads into a specific pipeline/status
AMO_PIPELINE_ID=
AMO_STATUS_ID=

# Optional lead source tag
AMO_SOURCE_TAG=Сайт stroyproject
